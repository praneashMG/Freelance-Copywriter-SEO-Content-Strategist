    <script>
    document.addEventListener('DOMContentLoaded', () => {
        const html = document.documentElement;

        // Load saved settings
        const savedLang = localStorage.getItem('language') || 'en';
        document.documentElement.setAttribute('dir', savedLang === 'ar' ? 'rtl' : 'ltr');

        const savedTheme = localStorage.getItem('theme') || 'light';
        applyTheme(savedTheme);

        // --- Theme Logic ---
        const themeToggles = [
            document.getElementById('theme-toggle'),
            document.getElementById('drawer-theme-toggle')
        ].filter(Boolean);
        
        function applyTheme(theme) {
            html.setAttribute('data-theme', theme);
            document.querySelectorAll('.light-icon').forEach(i => i.classList.toggle('hidden', theme === 'dark'));
            document.querySelectorAll('.dark-icon').forEach(i => i.classList.toggle('hidden', theme === 'light'));
        }

        themeToggles.forEach(btn => btn.addEventListener('click', () => {
            const next = html.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
            localStorage.setItem('theme', next);
            applyTheme(next);
        }));

        // --- Mobile Drawer Logic ---
        const menuDrawer = document.getElementById('mobile-menu-drawer');
        const menuContent = document.getElementById('drawer-content');
        const menuBackdrop = document.getElementById('drawer-backdrop');

        const openDrawer = () => {
            menuDrawer.classList.remove('pointer-events-none');
            menuContent.classList.remove('translate-y-[-100%]');
            menuBackdrop.classList.add('opacity-50', 'pointer-events-auto');
            document.body.style.overflow = 'hidden';
        };

        const closeDrawer = () => {
            menuContent.classList.add('translate-y-[-100%]');
            menuBackdrop.classList.remove('opacity-50', 'pointer-events-auto');
            setTimeout(() => { 
                menuDrawer.classList.add('pointer-events-none'); 
                document.body.style.overflow = ''; 
            }, 300);
        };

        document.getElementById('mobile-menu-open')?.addEventListener('click', openDrawer);
        document.getElementById('mobile-menu-close')?.addEventListener('click', closeDrawer);
        menuBackdrop?.addEventListener('click', closeDrawer);

        // --- Accordions ---
        const setupAccordion = (toggleId, menuId, iconId) => {
            const toggle = document.getElementById(toggleId);
            toggle?.addEventListener('click', () => {
                document.getElementById(menuId)?.classList.toggle('hidden');
                document.getElementById(iconId)?.classList.toggle('rotate-180');
            });
        };

        setupAccordion('mobile-homes-toggle', 'mobile-homes-menu', 'homes-icon');

        // --- RTL Logic ---
        const toggleRTL = () => {
            const current = localStorage.getItem('language') === 'ar' ? 'en' : 'ar';
            localStorage.setItem('language', current);
            document.documentElement.setAttribute('dir', current === 'ar' ? 'rtl' : 'ltr');
        };

        document.getElementById('lang-icon')?.addEventListener('click', toggleRTL);
        document.getElementById('mobile-lang-icon-drawer')?.addEventListener('click', toggleRTL);

        // ===== AUTH TOGGLE LOGIC =====
        (function() {
            var pill = document.getElementById('auth-toggle');
            if (!pill) return;
            var loginTab = document.getElementById('auth-tab-login');
            var signupTab = document.getElementById('auth-tab-signup');
            var page = window.location.pathname.split('/').pop() || '';
            function setActive(tab) {
                if (tab === 'signup') {
                    pill.setAttribute('data-active', 'signup');
                    loginTab.classList.remove('auth-toggle-tab--active'); loginTab.setAttribute('aria-selected','false');
                    signupTab.classList.add('auth-toggle-tab--active'); signupTab.setAttribute('aria-selected','true');
                } else {
                    pill.setAttribute('data-active', 'login');
                    signupTab.classList.remove('auth-toggle-tab--active'); signupTab.setAttribute('aria-selected','false');
                    loginTab.classList.add('auth-toggle-tab--active'); loginTab.setAttribute('aria-selected','true');
                }
            }
            setActive(page === 'signup.html' ? 'signup' : 'login');
loginTab.onclick = function(e) {
    e.preventDefault();
    e.stopPropagation();
    setActive('login');
    setTimeout(() => { window.location.assign('login.html'); }, 300);
};
signupTab.onclick = function(e) {
    e.preventDefault();
    e.stopPropagation();
    setActive('signup');
    setTimeout(() => { window.location.assign('signup.html'); }, 700);
};
        })();
    });
    </script>
</body>
</html>







