
<!DOCTYPE html>
<html lang="en" dir="ltr" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" href="/assets/fav.png" type="image/jpeg">
    <script src="tailwind.js"></script>
<script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <title>Blog | WordCraft Copywriting Insights</title>

    <style>
  /* ================================
   🟣 PURPLE + SLATE DESIGN SYSTEM
================================ */

/* ---------- LIGHT MODE ---------- */
:root,
html[data-theme='light'] {

  /* Backgrounds */
  --color-background: #F8FAFC;        /* soft neutral */
  --color-surface: #FFFFFF;           /* cards */
  --color-elevated: #F1F5F9;          /* sections */

  /* Text */
  --color-primary-text: #0F172A;      /* slate-900 */
  --color-secondary-text: #475569;

  /* Brand */
  --color-accent: #1E293B;            /* slate dark */
  --color-accent-light: #7C3AED;      /* purple */

  /* UI */
  --color-border: #E2E8F0;
  --color-hover: #EEF2F7;

  /* Footer */
  --color-footer-bg: #1E293B;
  --color-footer-text: #E2E8F0;
}


/* ---------- DARK MODE ---------- */
html[data-theme='dark'] {

  /* Backgrounds */
  --color-background: #0B1120;        /* deep slate */
  --color-surface: #0F172A;           /* cards */
  --color-elevated: #1E293B;          /* layers */

  /* Text */
  --color-primary-text: #E5E7EB;
  --color-secondary-text: #94A3B8;

  /* Brand */
  --color-accent: #334155;            /* lighter slate */
  --color-accent-light: #8B5CF6;      /* brighter purple */

  /* UI */
  --color-border: #1E293B;
  --color-hover: #1E293B;

  /* Footer */
  --color-footer-bg: #020617;         /* deep but smooth */
  --color-footer-text: #CBD5F5;
}
        
        body {
            background-color: var(--color-background);
            color: var(--color-primary-text);
            font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, "Noto Sans", sans-serif;
            transition: background-color 0.3s, color 0.3s;
            overflow-x: hidden;
        }
        
        /* Utility Class Aliases */
        .text-primary-text { color: var(--color-primary-text); }
        .text-secondary-text { color: var(--color-secondary-text); }
        .text-accent { color: var(--color-accent); }
        .text-accent-light { color: var(--color-accent-light); }
        .bg-background { background-color: var(--color-background); }
        .bg-hover { background-color: var(--color-hover); }
        .border-border { border-color: var(--color-border); }

        /* Updated Gradients */
        .bg-ocean-gradient {
            background: linear-gradient(135deg, #1F2937 0%, #2D5A3F 100%);
        }
        .bg-coral-gradient {
            background: linear-gradient(135deg, #7C3AED 0%, #F4D06F 100%);
        }

        /* Footer Specific Overrides */
        #main-footer {
            background-color: var(--color-footer-bg);
            color: var(--color-footer-text);
        }
        #main-footer .footer-heading {
            color: var(--color-accent-light) !important;
        }
        #main-footer .footer-link:hover {
            color: var(--color-accent-light);
            padding-inline-start: 4px;
        }

        /* Nav Link Underline Animation */
        .nav-link {
            position: relative;
            transition: color 0.3s;
            padding-top: 0.25rem;
            padding-bottom: 0.25rem;
        }
        .nav-link::after {
            content: '';
            position: absolute;
            left: 0; right: 0; bottom: 0;
            height: 2px;
            background-color: var(--color-accent-light);
            transform: scaleX(0);
            transition: transform 0.3s;
        }
        .nav-link:hover::after, .nav-link.active::after {
            transform: scaleX(1);
        }
        .nav-link.active, .nav-link:hover {
            color: var(--color-accent-light) !important;
        }

        /* DROPDOWN Logic */
        .dropdown-wrapper { position: relative; }
        .dropdown-wrapper::before {
            content: '';
            position: absolute;
            left: 0; right: 0; height: 20px;
            bottom: 100%;
            z-index: 100;
            background: transparent;
        }
        .dropdown-menu {
            position: absolute;
            top: calc(100% + 5px);
            left: 0;
            background-color: var(--color-background);
            border: 1px solid var(--color-border);
            border-radius: 0.5rem;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
            min-width: 220px;
            z-index: 1000;
            opacity: 0;
            visibility: hidden;
            transform: translateY(-10px);
            transition: all 0.3s ease;
        }
        .dropdown-wrapper:hover .dropdown-menu {
            opacity: 1; visibility: visible; transform: translateY(0);
            display: block;
        }
        .dropdown-menu a {
            display: block;
            padding: 0.75rem 1rem;
            color: var(--color-primary-text);
            text-decoration: none;
            font-size: 0.875rem;
            transition: all 0.2s ease;
            border-bottom: 1px solid var(--color-border);
        }
        .dropdown-menu a:last-child { border-bottom: none; }
        .dropdown-menu a:hover {
            background-color: var(--color-hover);
            color: var(--color-accent-light);
            padding-left: 1.25rem;
        }

        /* Dynamic Booking Button - Updated to Forest/Amber */
        .book-btn {
            background-color: var(--color-accent); 
            color: white;
            transition: all 0.3s ease;
        }

        html[data-theme='dark'] .book-btn {
            background-color: var(--color-accent-light); 
            color: #000;
        }

        .book-btn:hover {
            opacity: 0.9;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(31, 61, 43, 0.3);
        }

        /* ===== AUTH TOGGLE SWITCH (Desktop Only) ===== */
        .auth-toggle-wrap { display: none; }
        @media (min-width: 1280px) { .auth-toggle-wrap { display: flex; align-items: center; } }
        .auth-toggle-pill {
            position: relative; display: inline-flex; align-items: center;
            background-color: var(--color-hover); border: 1px solid var(--color-border);
            border-radius: 9999px; padding: 4px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08); overflow: hidden;
        }
        html[data-theme='dark'] .auth-toggle-pill {
            background-color: #1B2E23; border-color: #2D5A3F;
            box-shadow: 0 2px 12px rgba(0,0,0,0.3);
        }
        .auth-toggle-indicator {
            position: absolute; top: 4px; bottom: 4px; left: 4px;
            width: calc(50% - 4px);
            background-color: var(--color-accent); border-radius: 9999px;
            transition: transform 0.3s cubic-bezier(0.4,0,0.2,1); z-index: 0;
            box-shadow: 0 2px 8px rgba(31,61,43,0.25);
        }
        html[data-theme='dark'] .auth-toggle-indicator {
            background-color: var(--color-accent-light);
            box-shadow: 0 2px 8px rgba(230,179,37,0.3);
        }
        .auth-toggle-pill[data-active="signup"] .auth-toggle-indicator { transform: translateX(calc(100%)); }
        .auth-toggle-tab {
            position: relative; z-index: 1; display: inline-flex;
            align-items: center; justify-content: center;
            padding: 0.45rem 1.2rem; border-radius: 9999px;
            font-weight: 700; font-size: 0.875rem;
            color: var(--color-secondary-text); text-decoration: none;
            transition: color 0.25s ease; white-space: nowrap;
            min-width: 72px; text-align: center; user-select: none;
        }
        .auth-toggle-tab--active { color: #ffffff; }
        html[data-theme='dark'] .auth-toggle-tab--active { color: #000000; }
        .auth-toggle-tab:not(.auth-toggle-tab--active):hover { color: var(--color-accent); }
        html[data-theme='dark'] .auth-toggle-tab:not(.auth-toggle-tab--active):hover { color: var(--color-accent-light); }
        .auth-toggle-tab:focus-visible { outline: 2px solid var(--color-accent-light); outline-offset: 2px; border-radius: 9999px; }

        @media (max-width: 1024px) {
            .dropdown-menu { position: static; display: none; opacity: 1; visibility: visible; transform: none; box-shadow: none; }
            .dropdown-wrapper:hover .dropdown-menu { display: block; }
        }

        /* ===== DARK MODE OVERRIDES FOR HARDCODED COLORS ===== */
        html[data-theme='dark'] .bg-white,
        html[data-theme='dark'] section.bg-white,
        html[data-theme='dark'] section.py-24.bg-white,
        html[data-theme='dark'] section.py-20.bg-white {
            background-color: var(--color-background) !important;
        }
        html[data-theme='dark'] .bg-\[\#F1F5F2\],
        html[data-theme='dark'] section.bg-\[\#F1F5F2\],
        html[data-theme='dark'] .bg-\[\#F9FAF9\],
        html[data-theme='dark'] section.bg-\[\#F9FAF9\] {
            background-color: var(--color-hover) !important;
        }
        html[data-theme='dark'] .text-\[\#1F2937\],
        html[data-theme='dark'] h2.text-\[\#1F2937\],
        html[data-theme='dark'] h3.text-\[\#1F2937\],
        html[data-theme='dark'] h4.text-\[\#1F2937\],
        html[data-theme='dark'] p.text-\[\#1F2937\] {
            color: var(--color-primary-text) !important;
        }
        html[data-theme='dark'] .text-accent {
            color: var(--color-accent-light) !important;
        }
        html[data-theme='dark'] .text-gray-600,
        html[data-theme='dark'] .text-gray-500,
        html[data-theme='dark'] .text-gray-400 {
            color: var(--color-secondary-text) !important;
        }
        html[data-theme='dark'] .border-gray-100,
        html[data-theme='dark'] .border-gray-200 {
            border-color: var(--color-border) !important;
        }
        /* Cards with white/tinted backgrounds */
        html[data-theme='dark'] .bg-white.rounded-2xl,
        html[data-theme='dark'] .bg-white.rounded-3xl,
        html[data-theme='dark'] .bg-white.p-8,
        html[data-theme='dark'] .bg-white.p-10 {
            background-color: var(--color-hover) !important;
        }
        /* Icon circles */
        html[data-theme='dark'] .bg-\[\#F1F5F2\].rounded-full {
            background-color: var(--color-border) !important;
            color: var(--color-primary-text) !important;
        }
        /* Service/feature cards */
        html[data-theme='dark'] .group.p-8.bg-\[\#F1F5F2\] {
            background-color: var(--color-hover) !important;
        }
        /* Icon boxes */
        html[data-theme='dark'] .bg-\[\#1F2937\].text-\[\#7C3AED\] {
            background-color: var(--color-accent) !important;
        }
        /* Stats / number sections */
        html[data-theme='dark'] .bg-\[\#F9FAF9\] .text-gray-600 {
            color: var(--color-secondary-text) !important;
        }
        /* Testimonial cards */
        html[data-theme='dark'] .bg-white.shadow {
            background-color: var(--color-hover) !important;
        }

        /* --- DARK MODE BUTTON CONTRAST FIX --- */
        html[data-theme='dark'] .bg-\[var\(--color-primary-text\)\],
        html[data-theme='dark'] .hover\:bg-\[var\(--color-primary-text\)\]:hover,
        html[data-theme='dark'] .group:hover .group-hover\:bg-\[var\(--color-primary-text\)\] {
            color: #0F172A !important; /* Dark slate text on light background */
        }
        
        /* If the button specifically uses text-white but has a light primary-text background */
        html[data-theme='dark'] .bg-\[var\(--color-primary-text\)\].text-white,
        html[data-theme='dark'] .hover\:bg-\[var\(--color-primary-text\)\]:hover.hover\:text-white,
        html[data-theme='dark'] .group:hover .group-hover\:bg-\[var\(--color-primary-text\)\].group-hover\:text-white {
            color: #0F172A !important;
        }

        /* General fix for white text on light hover backgrounds */
        html[data-theme='dark'] .hover\:text-white:hover {
            color: #0F172A !important;
        }
        html[data-theme='dark'] .group:hover .group-hover\:text-white {
            color: #0F172A !important;
        }
        /* Exceptions: keep white text on brand/accent backgrounds */
        html[data-theme='dark'] .bg-\[var\(--color-accent-light\)\].text-white,
        html[data-theme='dark'] .hover\:bg-\[var\(--color-accent-light\)\]:hover,
        html[data-theme='dark'] .bg-purple-600.text-white {
            color: #FFFFFF !important;
        }
        /* RTL FIX - ONLY DIRECTION */
html[dir="rtl"] .auth-toggle-indicator {
    left: auto;
    right: 4px;
}

html[dir="rtl"] .auth-toggle-pill[data-active="signup"] .auth-toggle-indicator {
    transform: translateX(-100%);
}
    </style>
</head>
<body class="antialiased flex flex-col min-h-screen">

    <header class="sticky top-0 z-50 transition-colors duration-300 shadow-xl border-b border-border bg-background" id="main-header">
        <nav class="container mx-auto px-4 sm:px-6 lg:px-8 py-3 flex items-center h-[70px]">
            <!-- Brand (Left) -->
            <div class="flex-shrink-0">
                <a href="index.html" class="text-3xl font-serif font-extrabold tracking-tight text-accent-light">    
                    WordCraft
                </a>
            </div>

            <!-- Menu (Center) -->
            <div class="hidden xl:flex flex-grow justify-center">
                <div class="flex items-center space-x-6 rtl:space-x-reverse text-primary-text font-medium">
                    <div class="dropdown-wrapper">
                        <button class="nav-link flex items-center">
                            Home
                            <svg class="w-3 h-3 ml-1 relative top-[2.5px] transition-transform duration-200 text-primary-text" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                        </button>
                        <div class="dropdown-menu">
                            <a href="index.html">Home 1</a>
                            <a href="home2.html">Home 2</a>
                        </div>
                    </div>
                    <a href="service.html" class="nav-link">Services</a>
                    <a href="portfolio.html" class="nav-link">Portfolio</a>
                    <a href="blog.html" class="nav-link active font-bold">Blog</a>
                    <a href="about.html" class="nav-link">About</a>
                    <a href="contact.html" class="nav-link">Contact</a>
                    <a href="resources.html" class="nav-link">Resources</a>
                    <a href="casestudy.html" class="nav-link">Case Studies</a>
                    <a href="faq.html" class="nav-link">FAQ</a>
                </div>
            </div>

            <!-- Icons/Auth (Right) -->
            <div class="hidden xl:flex items-center space-x-4">
                <div class="flex items-center space-x-4 rtl:space-x-reverse">
                    <button id="theme-toggle" class="icon-btn text-primary-text hover:text-accent-light p-1.5 rounded-full transition duration-200">
                        <svg class="w-6 h-6 light-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                        <svg class="w-6 h-6 dark-icon hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path></svg>
                    </button>
                    <button id="lang-icon" class="text-primary-text hover:text-accent-light p-1.5 rounded-full transition duration-200">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7.5 21 3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" />
                        </svg>
                    </button>
                    <div class="auth-toggle-wrap" role="tablist" aria-label="Authentication options">
                        <div class="auth-toggle-pill" id="auth-toggle">
                            <span class="auth-toggle-indicator" id="auth-toggle-indicator" aria-hidden="true"></span>
                            <a href="login.html" role="tab" id="auth-tab-login"
                               class="auth-toggle-tab auth-toggle-tab--active" aria-selected="true">Login</a>
                            <a href="signup.html" role="tab" id="auth-tab-signup"
                               class="auth-toggle-tab" aria-selected="false">Sign Up</a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Mobile Menu Toggle (Always Right) -->
            <div class="xl:hidden ml-auto flex items-center space-x-4">
                <button id="mobile-menu-open" class="icon-btn text-primary-text hover:text-accent-light p-1.5 rounded-full transition duration-200">
                    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" /></svg>
                </button>
            </div>
        </nav>
    </header>
    <main class="flex-grow">
<!-- 1. INSIGHTS HERO -->
<section class="py-20 lg:py-32 bg-[var(--color-background)] border-b border-[var(--color-border)]">
    <div class="container mx-auto px-4 flex justify-center">
        
        <div class="max-w-4xl text-center flex flex-col items-center">
            
            <!-- Top Label -->
            <div class="flex items-center justify-center space-x-3 mb-8">
                <span class="h-px w-12 bg-[var(--color-accent-light)]"></span>
                <span class="text-[var(--color-accent-light)] font-bold tracking-[0.4em] uppercase text-[10px]">
                    The Insight Archive
                </span>
                <span class="h-px w-12 bg-[var(--color-accent-light)]"></span>
            </div>

            <!-- Heading -->
            <h1 class="text-5xl md:text-7xl lg:text-8xl font-serif font-bold text-[var(--color-primary-text)] leading-tight mb-8 tracking-tighter">
                Narrative <br>
                & <span class="italic text-[var(--color-secondary-text)]">Intelligence.</span>
            </h1>

            <!-- Description -->
            <p class="text-lg md:text-xl text-[var(--color-secondary-text)] leading-relaxed max-w-2xl">
                Exploring the intersection of behavioral psychology, semantic SEO, and high-conversion storytelling. Strategies for brands that demand authority.
            </p>

        </div>

    </div>
</section>

<!-- 2. EDITORIAL BENTO GRID -->
<section class="py-24 bg-[var(--color-surface)]">
    <div class="container mx-auto px-4">
        <div class="mb-16">
            <h2 class="text-3xl font-serif font-bold text-[var(--color-primary-text)] uppercase tracking-tight">Recent Insights</h2>
            <div class="h-1 w-20 bg-[var(--color-accent-light)] mt-4"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6 h-auto md:h-[800px]">
            <!-- Featured Article -->
            <div class="md:col-span-2 md:row-span-2 relative overflow-hidden border border-[var(--color-border)] group bg-[var(--color-background)]">
                <img src="/assets/r1.jpg" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-1000" alt="Strategy Board">
                <div class="absolute bottom-0 left-0 right-0 p-8 bg-gradient-to-t from-black/80 to-transparent text-white">
                    <h4 class="text-2xl font-serif font-bold leading-tight">Semantic Dominance: Moving Beyond Keyword Density</h4>
                </div>
            </div>
            <!-- Secondary Article -->
            <div class="md:col-span-2 relative overflow-hidden border border-[var(--color-border)] group bg-[var(--color-background)]">
                <img src="/assets/r2.jpg" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-1000" alt="Conference Room">
                <div class="absolute bottom-0 left-0 right-0 p-8 bg-gradient-to-t from-black/80 to-transparent text-white">
                    <h4 class="text-xl font-serif font-bold leading-tight">The Psychology of the Call-to-Action</h4>
                </div>
            </div>
            <!-- Smaller Grid Items -->
            <div class="relative overflow-hidden border border-[var(--color-border)] group bg-[var(--color-background)]">
                <img src="/assets/r3.jpg" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-1000" alt="Team Work">
                <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-all flex items-center justify-center p-4 text-center">
                    <p class="text-white text-[10px] font-bold uppercase tracking-[0.2em]">B2B Case Study</p>
                </div>
            </div>
            <div class="relative overflow-hidden border border-[var(--color-border)] group bg-[var(--color-background)]">
                <img src="/assets/r4.jpg" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-1000" alt="Consultation">
                <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-all flex items-center justify-center p-4 text-center">
                    <p class="text-white text-[10px] font-bold uppercase tracking-[0.2em]">Brand Voice Guide</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- 3. STRATEGIC RIGOR (VERTICAL STAGGERED) -->
<section class="py-24 bg-[var(--color-background)]">
    <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
            <div class="space-y-12">
                <div class="border-l-4 border-[var(--color-accent-light)] pl-8 rtl:pl-0 rtl:pr-8 rtl:border-l-0 rtl:border-r-4">
                    <h3 class="text-4xl font-serif font-bold text-[var(--color-primary-text)] mb-6">Behavioral <br><span class="italic">Analysis.</span></h3>
                    <p class="text-[var(--color-secondary-text)] leading-relaxed">I utilize deep semantic analysis and heat-mapping data to move beyond surface-level writing. Every word is chosen based on empirical audience data and intent mapping.</p>
                </div>
                <div class="relative group h-80 overflow-hidden border border-[var(--color-border)]">
                    <img src="/assets/r6.jpg" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700" alt="Data Analysis">
                </div>
            </div>
            <div class="lg:pt-32">
                <div class="relative group h-[500px] overflow-hidden border border-[var(--color-border)]">
                    <img src="/assets/r7.jpg" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700" alt="Content Architecture">
                    <div class="absolute inset-0 border-[20px] border-[var(--color-surface)] m-6 pointer-events-none opacity-20"></div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- 4. PERFORMANCE CHRONICLE -->
<section class="py-24 bg-[var(--color-elevated)] border-y border-[var(--color-border)]">
    <div class="container mx-auto px-4">
        <div class="text-center mb-16">
            <h2 class="text-4xl font-serif font-bold text-[var(--color-primary-text)] mb-4">Milestones</h2>
            <p class="text-[10px] font-bold text-[var(--color-accent-light)] uppercase tracking-[0.4em]">Proven Revenue Impact</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <!-- Milestone 1 -->
            <div class="bg-[var(--color-surface)] border border-[var(--color-border)] p-1 group hover:border-[var(--color-accent-light)] transition-all">
